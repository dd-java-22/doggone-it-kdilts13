<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="@dimen/activity_horizontal_margin">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/scan_display_title"/>

    <ImageView
      android:id="@+id/saved_image"
      android:layout_width="match_parent"
      android:layout_height="220dp"
      android:layout_marginTop="@dimen/activity_vertical_margin"
      android:contentDescription="@string/saved_scan_image_content_description"
      android:scaleType="centerCrop"/>

    <TextView
      android:id="@+id/summary_status_text"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="@string/scan_display_missing_image"
      android:visibility="gone"/>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/activity_vertical_margin"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/breed_name_text"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/scan_display_unknown_breed"
          android:textAppearance="?attr/textAppearanceTitleMedium"/>

        <TextView
          android:id="@+id/breed_confidence_text"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginTop="4dp"
          android:textAppearance="?attr/textAppearanceBodyMedium"
          android:visibility="gone"/>

      </LinearLayout>

      <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/favorite_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scan_display_favorite_toggle"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
      android:id="@+id/content_tab_group"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/activity_vertical_margin"
      app:singleSelection="true"
      app:selectionRequired="true">

      <com.google.android.material.button.MaterialButton
        android:id="@+id/tab_facts"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/scan_display_tab_facts"/>

      <com.google.android.material.button.MaterialButton
        android:id="@+id/tab_notes"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/scan_display_tab_notes"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <LinearLayout
      android:id="@+id/tab_content_container"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/activity_vertical_margin"
      android:background="?attr/colorSurfaceContainerLow"
      android:minHeight="140dp"
      android:orientation="vertical"
      android:padding="16dp">

      <ProgressBar
        android:id="@+id/facts_loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"/>

      <TextView
        android:id="@+id/facts_placeholder_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scan_display_facts_placeholder"/>

      <TextView
        android:id="@+id/facts_details_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone"/>

      <TextView
        android:id="@+id/notes_placeholder_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scan_display_notes_placeholder"
        android:visibility="gone"/>

      <TextView
        android:id="@+id/notes_view_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:visibility="gone"/>

      <EditText
        android:id="@+id/notes_edit_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top|start"
        android:hint="@string/scan_display_notes_hint"
        android:inputType="textCapSentences|textMultiLine"
        android:minLines="4"
        android:visibility="gone"/>

      <LinearLayout
        android:id="@+id/notes_actions_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
          android:id="@+id/notes_edit_button"
          style="@style/Widget.Material3.Button.OutlinedButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="@string/scan_display_notes_edit_action"/>

        <com.google.android.material.button.MaterialButton
          android:id="@+id/notes_cancel_button"
          style="@style/Widget.Material3.Button.OutlinedButton"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:text="@string/scan_display_notes_cancel_action"/>

        <com.google.android.material.button.MaterialButton
          android:id="@+id/notes_save_button"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="8dp"
          android:text="@string/scan_display_notes_save_action"/>

      </LinearLayout>

    </LinearLayout>

  </LinearLayout>

</ScrollView>
